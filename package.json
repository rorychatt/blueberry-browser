{
  "name": "blueberry-browser",
  "version": "1.0.0",
  "description": "An Electron application with React and TypeScript",
  "homepage": "https://electron-vite.org",
  "author": "example.com",
  "main": "./out/main/index.js",
  "scripts": {
    "format": "prettier --write .",
    "lint": "vp lint .",
    "typecheck:node": "tsc --noEmit -p src/tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p src/tsconfig.web.json --composite false",
    "typecheck": "pnpm run typecheck:node && pnpm run typecheck:web",
    "start": "electron-vite preview -c src/electron.vite.config.ts",
    "dev": "electron-vite dev -c src/electron.vite.config.ts",
    "build": "pnpm run typecheck && electron-vite build -c src/electron.vite.config.ts",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "pnpm run build && electron-builder --dir --config src/electron-builder.yml",
    "build:win": "pnpm run build && electron-builder --win --config src/electron-builder.yml",
    "build:mac": "electron-vite build -c src/electron.vite.config.ts && electron-builder --mac --config src/electron-builder.yml",
    "build:linux": "electron-vite build -c src/electron.vite.config.ts && electron-builder --linux --config src/electron-builder.yml",
    "prepare": "vp config"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "4.0.8",
    "@ai-sdk/openai": "4.0.7",
    "@electron-toolkit/preload": "3.0.2",
    "@electron-toolkit/utils": "4.0.0",
    "@radix-ui/react-slot": "1.3.0",
    "ai": "7.0.15",
    "class-variance-authority": "0.7.1",
    "dotenv": "17.4.2",
    "lucide-react": "1.23.0",
    "react-markdown": "10.1.0",
    "remark-breaks": "4.0.0",
    "remark-gfm": "4.0.1"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "2.0.0",
    "@tailwindcss/postcss": "4.3.2",
    "@types/node": "26.1.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "autoprefixer": "10.5.2",
    "clsx": "2.1.1",
    "electron": "43.0.0",
    "electron-builder": "26.15.3",
    "electron-vite": "5.0.0",
    "postcss": "8.5.16",
    "prettier": "3.9.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.2",
    "typescript": "6.0.3",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.10.0",
      "onFail": "download"
    }
  }
}
